AI_PROVIDER=qwen
AI_MODEL=qwen-plus
AI_EMBEDDING_MODEL=text-embedding-v4
AI_EMBEDDING_DIMENSIONS=1024
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
MCP_DEFAULT_TIMEZONE=Asia/Tokyo
MCP_DEFAULT_LOCATION=日本 大阪
SEARCH_ENABLED=false
SEARCH_VECTOR_ENABLED=false
SEARCH_RERANK_ENABLED=false
SEARCH_RERANK_TOP_N=12
SEARCH_BASE_URL=http://localhost:9200
SEARCH_INDEX_NAME=do_not_miss_events
EVENT_EXPIRATION_INITIAL_DELAY_MS=60000
EVENT_EXPIRATION_DELAY_MS=300000
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=donotmiss
RABBITMQ_PASSWORD=donotmiss123
RABBITMQ_LISTENER_AUTO_STARTUP=true
APP_MQ_OUTBOX_ENABLED=true
APP_MQ_OUTBOX_BATCH_SIZE=20
APP_MQ_OUTBOX_MAX_ATTEMPTS=8
APP_MQ_OUTBOX_INITIAL_DELAY_MS=5000
APP_MQ_OUTBOX_DELAY_MS=5000
APP_MQ_OUTBOX_INITIAL_BACKOFF_SECONDS=5
APP_MQ_OUTBOX_MAX_BACKOFF_SECONDS=300
